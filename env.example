# Next.js Configuration
# Production URL (required for SEO + server-side API calls on Vercel)
NEXT_PUBLIC_APP_URL=https://himalayan-sound.com
NEXT_PUBLIC_APP_NAME="Himalayan Sound"
NEXT_PUBLIC_APP_DESCRIPTION="Authentic Himalayan singing bowls and meditation instruments"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-admin-password
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-key-here

# Google Drive API (for image storage)
GOOGLE_DRIVE_CLIENT_ID=your-google-drive-client-id
GOOGLE_DRIVE_CLIENT_SECRET=your-google-drive-client-secret
GOOGLE_DRIVE_API_KEY=your-google-drive-api-key
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# YouTube Data API v3 (for video uploads)
YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret

# SoundCloud API (for audio uploads)
SOUNDCLOUD_CLIENT_ID=your-soundcloud-client-id
SOUNDCLOUD_CLIENT_SECRET=your-soundcloud-client-secret

# Payment Processing
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Google Search Console — paste verification code from https://search.google.com/search-console
GOOGLE_SITE_VERIFICATION=

# Google Analytics (optional)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
FACEBOOK_PIXEL_ID=XXXXXXXXXX

# Site contact & social (optional overrides)
NEXT_PUBLIC_CONTACT_EMAIL=info@himalayan-sound.com
NEXT_PUBLIC_CONTACT_PHONE=+977-1-234-5678
NEXT_PUBLIC_CONTACT_ADDRESS=Kathmandu Valley, Nepal
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/himalayansound
NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@himalayansound

# Zoho Mail SMTP (contact form + order emails from the website)
# Setup guide: docs/zoho-mail-setup.md
# Use App Password if 2FA is on: Zoho Account → Security → App Passwords
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=587
ZOHO_SMTP_USER=info@himalayan-sound.com
ZOHO_SMTP_PASS=your-zoho-app-password
EMAIL_FROM_NAME=Himalayan Sound

# Social Media
FACEBOOK_APP_ID=your-facebook-app-id
TWITTER_CREATOR=@your-twitter-handle

# SEO
NEXT_PUBLIC_SITE_URL=https://himalayan-sound.com
NEXT_PUBLIC_SITE_NAME="Himalayan Sound"
NEXT_PUBLIC_SITE_DESCRIPTION="Authentic Himalayan singing bowls and meditation instruments"

# Capacitor Mobile App
CAPACITOR_APP_ID=com.himalayansound.app
CAPACITOR_SERVER_URL=https://himalayan-sound.com/uk
# Local dev on device: CAPACITOR_SERVER_URL=http://192.168.x.x:3000/uk

# Development
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# Netlify specific
NETLIFY_DEV=true
